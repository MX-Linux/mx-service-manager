#!/bin/bash

cmd="$*"
set -- $cmd
first="$1"
shift

if [[ "$first" == "/sbin/service" || "$first" == "service" ]]; then
    # service --status-all
    if [[ "$1" == "--status-all" ]]; then
        if command -v service >/dev/null 2>&1; then
            exec service --status-all
        else
            exec systemctl list-units --type=service --all
        fi
    else
        name="$1"; shift
        action="${1:-status}"; shift || true
        if command -v service >/dev/null 2>&1; then
            exec service "$name" "$action" "$@"
        else
            exec systemctl "$action" "$name" "$@"
        fi
    fi
else
    exec /bin/bash -c "$cmd"
fi
